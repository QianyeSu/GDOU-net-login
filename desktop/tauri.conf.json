{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GDOU Net Login",
  "version": "0.1.3",
  "identifier": "cn.gdou.netlogin",
  "build": {
    "beforeDevCommand": {
      "cwd": "../frontend",
      "script": "npm run dev",
      "wait": false
    },
    "beforeBuildCommand": {
      "cwd": "../frontend",
      "script": "npm run build",
      "wait": false
    },
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "GDOU Net Login",
        "width": 1180,
        "height": 760,
        "minWidth": 1040,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
    "csp": "default-src 'self'; img-src 'self' data: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDgyRDMwQjhDOEVCNEQ5RjAKUldUdzJiU09qQXZUZ3MxbCtUaHRHNndELzFKZkhGaGV2VkkyVVVoVHUvcUcxakxMT3dPSzJhNk0K",
      "endpoints": [
        "https://github.com/QianyeSu/GDOU-net-login/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
