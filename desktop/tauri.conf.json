{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GDOU Net Login",
  "version": "0.1.0",
  "identifier": "cn.gdou.netlogin",
  "build": {
    "beforeDevCommand": {
      "cwd": "../frontend",
      "script": "npm run dev",
      "wait": false
    },
    "beforeBuildCommand": {
      "cwd": "../frontend",
      "script": "npm run build",
      "wait": false
    },
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "GDOU Net Login",
        "width": 1180,
        "height": 760,
        "minWidth": 1040,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
